# Base URL of the FastAPI backend.
# Local dev: http://localhost:8000
# Beta (set this as a Vercel env var): https://vinci-automation-api-beta.onrender.com
VITE_API_BASE_URL=http://localhost:8000

# Supabase project credentials (Project Settings -> API).
# The frontend uses Supabase Auth (Google OAuth + email/password) for login,
# so it needs the project URL and the anon/publishable key (safe to expose).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
