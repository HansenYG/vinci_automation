# ---------------------------------------------------------------------
# Vinci Automation — backend environment
# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# ---------------------------------------------------------------------

# Comma-separated origins allowed to call the API (CORS)
CORS_ORIGINS=http://localhost:5173

# --- Supabase (Project Settings -> API) ---
# Backend uses the service_role key (secret, server-side only).
SUPABASE_URL=
SUPABASE_KEY=

# --- Supabase Auth (Phase 1 login) ---
# Users sign in with Supabase Auth (Google OAuth or email+password) on the
# frontend; the backend verifies the access token. Tokens are verified against
# the project's JWKS (derived from SUPABASE_URL) for asymmetric signing keys
# (ES256/RS256, the modern default), so no extra secret is required.
# Only set SUPABASE_JWT_SECRET if your project still issues legacy HS256 tokens.
SUPABASE_JWT_SECRET=
# Email domain granted the Admin role on first sign-in (Business Rules s.3).
VINCI_EMAIL_DOMAIN=vinciai.academy

# --- JWT Authentication (custom backend tokens) ---
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@vinciautomation.com
ADMIN_PASSWORD=

# --- WATI (WhatsApp) ---
# ENDPOINT_BASE includes the tenant id, e.g. https://live-mt-server.wati.io/111307
WATI_API_URL=
WATI_ACCESS_TOKEN=
WATI_TEMPLATE_UNASSIGNED=unassigned_lesson_notification_refined
WATI_TEMPLATE_CONFIRMATION=tutor_confirmation_extra_info
WATI_TEMPLATE_CANCEL_ADMIN=tutor_cancellation_or_reschedule_admin_reminder
WATI_BROADCAST_PREFIX=vinci
# Pick any random string; append it to the webhook URL as ?token=THIS_VALUE
WATI_WEBHOOK_SECRET=

# Admin + fallback WhatsApp numbers (digits only, no leading +)
ADMIN_WHATSAPP=
FALLBACK_WHATSAPP_HK=85252408480
FALLBACK_WHATSAPP_ID=6281287776026

# --- Business rules ---
URGENT_WINDOW_DAYS=7
REBLAST_INTERVAL_HOURS=24
TIMEZONE=Asia/Hong_Kong          # Server timezone for date references

# --- Airtable (optional, only for one-time legacy migration) ---
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TEACHERS_TABLE=Teachers
AIRTABLE_LESSONS_TABLE=Lessons

# --- LLM for the chatbot ---
# provider = "ollama" (local, default) or "openai" (OpenAI-compatible, e.g. Groq)
LLM_PROVIDER=ollama
LLM_API_KEY=                    # required for openai-compatible providers
LLM_BASE_URL=                   # defaults: ollama=http://localhost:11434, openai=https://api.groq.com/openai/v1
LLM_MODEL=                      # defaults: ollama=llama3.1, openai=llama-3.1-8b-instant
LLM_TIMEOUT_SECONDS=60

# --- In-process scheduler ---
# Leave false in production; use a Render Cron Job hitting
# /api/scheduling/run-due-reminders instead.
ENABLE_SCHEDULER=false
SCHEDULER_TICK_MINUTES=60
